# Farcaster manifest generator (scripts/generate-manifest.mjs)
# Copy to .env.local and fill in — never commit .env.local

# ── Vercel → Project → Settings → Environment Variables ─────────────────────
# Add these in the Vercel dashboard (Production + Preview recommended):

# Canonical public URL — fixes OG images, Farcaster embeds, share links
NEXT_PUBLIC_SITE_URL=https://baza-mining-app.vercel.app

# Base Builder Code (base.dev → Settings → Builder Codes)
NEXT_PUBLIC_BASE_BUILDER_CODE=bc_5urownup

# Farcaster mini app page for Share buttons
NEXT_PUBLIC_FARCASTER_MINIAPP_URL=https://farcaster.xyz/miniapps/DwoLrAk1IJA-/baza-mining

# Faster Base RPC — pick ONE option:
# Option A (recommended): paste only the API key from Alchemy dashboard
# ALCHEMY_API_KEY=your_alchemy_api_key
# Option B: full HTTPS URL
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_alchemy_api_key

# BazaToken deploy block — speeds up first tx-counter scan
BAZA_TOKEN_DEPLOY_BLOCK=46494397

# ── Local manifest signing only (never add private keys to Vercel) ──────────

# Custody wallet private key (Warpcast → Settings → Advanced → custody / recovery)
FARCASTER_CUSTODY_PRIVATE_KEY=0x

# Optional: omit to auto-resolve FID from custody address via Optimism IdRegistry
# FARCASTER_FID=12345

# Must match the domain where farcaster.json is hosted (no https://)
FARCASTER_DOMAIN=baza-mining-app.vercel.app
